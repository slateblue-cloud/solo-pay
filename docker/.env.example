# SoloPay Docker Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control
#
# NOTE: docker-compose reads .env from this directory when present.
#       docker-compose.yaml (local) requires CMC_API_KEY for price-service.
#       docker-compose-amoy.yaml requires SIGNER_PRIVATE_KEY (and optionally RELAY_API_KEY).

# =============================================================================
# docker-compose.yaml (local Hardhat)
# =============================================================================

# Price Service - token price for fiat conversion (POST /payments with currency)
# Get a free API key at https://coinmarketcap.com/api/
CMC_API_KEY=your_coinmarketcap_api_key_here


# =============================================================================
# docker-compose-amoy.yaml (Polygon Amoy)
# =============================================================================
# Generate keys: cast wallet new (or openssl rand -hex 32)

# Relayer private key (with or without 0x prefix). For simple-relayer when enabled.
RELAYER_PRIVATE_KEY=your_64_char_hex_private_key_here
RELAYER_ADDRESS=0xYourRelayerAddressHere

# Gateway signer private key - signs EIP-712 payment authorizations (required for Amoy)
SIGNER_PRIVATE_KEY=your_64_char_hex_private_key_here

# Optional: API key for relay-api (msq-relayer-service). Default in compose: amoy-dev-api-key
# RELAY_API_KEY=amoy-dev-api-key

# =============================================================================
# Optional - Sample Merchant (build args, have defaults in docker-compose.yaml)
# =============================================================================
# NEXT_PUBLIC_SOLO_PAY_PUBLIC_KEY=pk_live_xxx
# NEXT_PUBLIC_WIDGET_URL=http://localhost:3005
